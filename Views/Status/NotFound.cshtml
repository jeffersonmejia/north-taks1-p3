@using NorthwindStore.Controllers
@model ErrorViewModel
@{
    ViewData["Title"] = "Not found";
}
<section class="glass-panel narrow fade-in error-page">
    <div class="error-icon">
        <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="var(--muted)" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="10"/>
            <path d="M16 16s-1.5-2-4-2-4 2-4 2"/>
            <line x1="9" y1="9" x2="9.01" y2="9"/>
            <line x1="15" y1="9" x2="15.01" y2="9"/>
        </svg>
    </div>
    <h1 class="error-title">404 — Page not found</h1>
    <p class="error-message">@Model.Message</p>
    <div class="error-actions">
        <a class="btn btn-primary" href="/">Go to home</a>
    </div>
</section>
