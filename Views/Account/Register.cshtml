@model RegisterViewModel
@{
    ViewData["Title"] = "Register";
}
<section class="auth-wrap">
    <form class="glass-panel auth-card fade-in" asp-action="Register" method="post">
        <h1>Create account</h1>
        <div asp-validation-summary="ModelOnly" class="validation"></div>
        <label asp-for="FullName"></label>
        <input asp-for="FullName" />
        <span asp-validation-for="FullName" class="validation"></span>
        <label asp-for="Email"></label>
        <input asp-for="Email" autocomplete="email" />
        <span asp-validation-for="Email" class="validation"></span>
        <label asp-for="Password"></label>
        <input asp-for="Password" autocomplete="new-password" />
        <span asp-validation-for="Password" class="validation"></span>
        <label asp-for="ConfirmPassword"></label>
        <input asp-for="ConfirmPassword" autocomplete="new-password" />
        <span asp-validation-for="ConfirmPassword" class="validation"></span>
        <button class="btn btn-primary" type="submit">Register</button>
    </form>
</section>
