@{
    ViewData["Title"] = "Access denied";
}
<section class="glass-panel narrow fade-in error-page">
    <div class="error-icon">
        <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="var(--danger)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <rect x="3" y="11" width="18" height="11" rx="2" ry="2"/>
            <path d="M7 11V7a5 5 0 0 1 10 0v4"/>
        </svg>
    </div>
    <h1 class="error-title">Access denied</h1>
    <p class="error-message">Your account does not have permission to open this area.<br/>If you believe this is a mistake, contact the administrator.</p>
    <div class="error-actions">
        <a class="btn btn-primary" asp-controller="Home" asp-action="Index">Go to home</a>
        <a class="btn btn-ghost" asp-controller="Account" asp-action="Login">Sign in as another user</a>
    </div>
</section>
