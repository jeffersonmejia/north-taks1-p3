@model InventoryReportViewModel
@{
    ViewData["Title"] = "Inventory";
}
<section class="glass-panel">
    <div class="admin-head">
        <h1>@Model.Title</h1>
        <div class="segmented">
            <a asp-action="LowStock">Low</a>
            <a asp-action="OutOfStock">No stock</a>
            <a asp-action="Discontinued">Discontinued</a>
        </div>
    </div>
    <partial name="_InventoryTable" model="Model" />
    <partial name="_Pagination" model="Model" />
</section>
