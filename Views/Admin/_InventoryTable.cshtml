@model InventoryReportViewModel
<div class="table-wrap">
    <table class="admin-table">
        <thead>
            <tr><th>Product</th><th>Price</th><th>Stock</th><th>Status</th><th>Disc.</th><th>Actions</th></tr>
        </thead>
        <tbody>
        @foreach (var product in Model.Products)
        {
            <tr>
                <td>@product.Name</td>
                <td>@product.UnitPrice.ToString("C")</td>
                <td>@product.Stock</td>
                <td>@(product.Discontinued ? "Discontinued" : product.Stock <= 0 ? "Out" : "Active")</td>
                <td>
                    <label class="toggle">
                        <input type="checkbox" class="toggle-disc" data-product-id="@product.ProductId" @(product.Discontinued ? "checked" : "") />
                        <span class="toggle-slider"></span>
                    </label>
                </td>
                <td class="action-row">
                    <button class="btn btn-ghost btn-quick" type="button" data-product-id="@product.ProductId" data-operation="increase">+1</button>
                    <button class="btn btn-ghost btn-quick" type="button" data-product-id="@product.ProductId" data-operation="decrease">-1</button>
                    <a class="btn btn-ghost" asp-controller="AdminInventory" asp-action="UpdateStock" asp-route-productId="@product.ProductId" asp-route-operation="increase">Adjust</a>
                </td>
            </tr>
        }
        </tbody>
    </table>
</div>
