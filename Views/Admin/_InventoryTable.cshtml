@model InventoryReportViewModel
<div class="table-wrap">
    <table class="admin-table">
        <thead>
            <tr><th>Product</th><th>Price</th><th>Stock</th><th>Status</th><th>Actions</th></tr>
        </thead>
        <tbody>
        @foreach (var product in Model.Products)
        {
            <tr>
                <td>@product.Name</td>
                <td>@product.UnitPrice.ToString("C")</td>
                <td>@product.Stock</td>
                <td>@(product.Discontinued ? "Discontinued" : product.Stock <= 0 ? "Out" : "Active")</td>
                <td class="action-row">
                    <a class="btn btn-ghost" asp-controller="AdminInventory" asp-action="UpdateStock" asp-route-productId="@product.ProductId" asp-route-operation="increase">Increase</a>
                    <a class="btn btn-ghost" asp-controller="AdminInventory" asp-action="UpdateStock" asp-route-productId="@product.ProductId" asp-route-operation="decrease">Decrease</a>
                </td>
            </tr>
        }
        </tbody>
    </table>
</div>
