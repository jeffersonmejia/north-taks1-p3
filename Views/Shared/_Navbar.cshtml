<header class="navbar">
    <a class="brand" asp-controller="Home" asp-action="Index">NorthwindStore</a>
    <nav class="nav-links">
        @if (User.Identity?.IsAuthenticated == true && User.IsInRole(RoleNames.Customer))
        {
            <a asp-controller="Products" asp-action="Index">Products</a>
            <a asp-controller="Cart" asp-action="Index">Cart</a>
            <a asp-controller="Orders" asp-action="MyOrders">My orders</a>
        }
        @if (User.Identity?.IsAuthenticated == true && User.IsInRole(RoleNames.Admin))
        {
            <a asp-controller="AdminInventory" asp-action="Inventory">Inventory</a>
            <a asp-controller="AdminOrders" asp-action="Orders">Orders</a>
        }
    </nav>
    <div class="nav-actions">
        @if (User.Identity?.IsAuthenticated == true)
        {
            <span class="user-chip">@User.Identity.Name</span>
            <form asp-controller="Account" asp-action="Logout" method="post">
                <button class="btn btn-ghost" type="submit">Logout</button>
            </form>
        }
        else
        {
            <a class="btn btn-ghost" asp-controller="Account" asp-action="Login">Login</a>
            <a class="btn btn-primary" asp-controller="Account" asp-action="Register">Register</a>
        }
    </div>
</header>
