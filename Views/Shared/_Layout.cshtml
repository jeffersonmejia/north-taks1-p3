<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@ViewData["Title"] - NorthwindStore</title>
    <link rel="stylesheet" href="~/css/main.css" asp-append-version="true" />
</head>
<body>
    <div class="ambient"></div>
    <partial name="_Navbar" />
    <main class="shell page-transition">
        @if (TempData["Success"] is string success)
        {
            <div class="alert alert-success">@success</div>
        }
        @if (TempData["Error"] is string error)
        {
            <div class="alert alert-error">@error</div>
        }
        @RenderBody()
    </main>
    <script src="~/js/cart.js" asp-append-version="true"></script>
    <script src="~/js/inventory.js" asp-append-version="true"></script>
    <script src="~/js/validations.js" asp-append-version="true"></script>
    <script src="~/js/animations.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
